{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
      "builder": "NIXPACKS",
      "nixpacks": {
        "phpVersion": "8.3",
        "build": {
          "command": "mkdir -p bootstrap/cache && composer install --no-dev --no-interaction --prefer-dist --optimize-autoloader"
        }
      }
    },
    "deploy": {
      "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT}",
      "healthcheckPath": "/health"
    }
  }